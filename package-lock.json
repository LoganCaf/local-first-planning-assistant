{
  "name": "llmclassproject",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "llmclassproject",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/server": {
      "name": "@llm/server",
      "version": "0.1.0"
    },
    "node_modules/@llm/server": {
      "resolved": "apps/server",
      "link": true
    },
    "node_modules/@llm/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "packages/shared": {
      "name": "@llm/shared",
      "version": "0.1.0"
    }
  }
}
