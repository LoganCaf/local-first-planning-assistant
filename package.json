{
  "name": "llmclassproject",
  "version": "0.1.0",
  "description": "Local-first scheduling assistant monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "npm run dev --workspace @llm/web",
    "dev:server": "npm run dev --workspace @llm/server",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces --if-present",
    "format": "npm run format --workspaces --if-present"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
